# ============================
# EduGenie Environment Config
# ============================

# MongoDB Connection String (paste your connection string here)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/edugenie?retryWrites=true&w=majority
MONGODB_DB_NAME=edugenie

# JWT Secret Key (generate a strong random string)
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Google Gemini API Key
GEMINI_API_KEY=your-gemini-api-key-here

# App Config
APP_NAME=EduGenie
APP_VERSION=1.0.0
DEBUG=True
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# File Upload
MAX_UPLOAD_SIZE_MB=10
UPLOAD_DIR=uploads
